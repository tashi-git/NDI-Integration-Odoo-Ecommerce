<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="website_ndi_login_inherit" inherit_id="web.login">
        <xpath expr="//div[hasclass('oe_login_buttons')]" position="after">

            <div class="mt-3">
                <a href="/ndi/login" class="ndi-login-btn w-100">
                    <img src="/website_ndi_integration/static/src/img/ndi_logo.png"
                         alt="NDI"
                         class="ndi-login-btn-icon"/>
                    <span>Login with Bhutan NDI</span>
                </a>
            </div>

        </xpath>
    </template>
</odoo>
